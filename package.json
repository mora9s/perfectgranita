{
  "name": "perfect-granita",
  "version": "1.0.0",
  "description": "Slushi Party mobile app for Ninja Slushi and Ninja Slushi Max recipes, with legacy CLI support",
  "main": "expo-router/entry",
  "bin": {
    "perfectgranita": "./src/index.js"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "cli": "node src/index.js",
    "test": "rm -rf .test-dist && tsc -p tsconfig.test.json && node --test .test-dist/tests/recipe-persistence.test.js"
  },
  "keywords": [
    "granita",
    "sicily",
    "dessert",
    "frozen",
    "recipe",
    "expo",
    "react-native"
  ],
  "author": "mora9s",
  "license": "MIT",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "expo": "^55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-haptics": "^55.0.14",
    "expo-router": "~55.0.11",
    "expo-status-bar": "~3.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^55.0.7",
    "typescript": "~5.9.2"
  },
  "private": true
}
